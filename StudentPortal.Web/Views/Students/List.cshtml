@model List<StudentPortal.Web.Models.Entities.Student>

<h1>Students</h1>
    
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Email</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach(var student in Model)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.Email</td>
                <td>
                    <a asp-action="Edit" asp-controller="Students">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>