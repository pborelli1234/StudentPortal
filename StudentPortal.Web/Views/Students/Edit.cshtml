@model StudentPortal.Web.Models.EditStudentViewModel

<h1>Edit Student</h1>

<form method="post">

    <div class="mt-3">
        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
    </div>

    <div class="mt-3">
        <label class="form-label">Name:</label>
        <input type="text" class="form-control" asp-for="Name" value="@Model.Name" />
    </div>

    <div class="mt-3">
        <label class="form-label">Email:</label>
        <input type="text" class="form-control" asp-for="Email" value="@Model.Email" />
    </div>

    <div class="mt-3">
        <label class="form-label">Phone Number:</label>
        <input type="text" class="form-control" asp-for="Phone" value="@Model.Phone" />
    </div>

    <div class="mt-3">
        <input type="checkbox" class="form-check-input" id="Subscribed" asp-for="Subscribed" />
        <label class="form-check-label" for="Subscribed">Subscribed</label>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
    </div>

    <input id="hdStudentId" type="hidden" asp-for="@Model.Id" value="@Model.Id" />

</form>